      },
      {
        "parameters": {
          "jsCode": "const { agenda_jornada, agenda_sel, code_med } = $input.first().json.body;\n\nconst { dia, mes } = JSON.parse(agenda_sel);\nconst hora_inf = agenda_jornada == \"Mañana\" ? \"06:00\" : \"12:00\";\nconst hora_sup = agenda_jornada == \"Mañana\" ? \"11:59\" : \"18:00\";\n\nreturn {\n  dia,\n  mes,\n  hora_inf,\n  hora_sup,\n  code_med,\n  agenda_sel\n};\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          224,
          0
        ],
        "id": "8202a101-0992-4f0c-923b-e1aa2df92559",
        "name": "Formato Datos"
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT `id`, `hora_consulta` AS 'agenda_hora'\nFROM u125634063_ins_andes.Agenda \nWHERE day(fecha_consulta) = $1 AND\nmonth(fecha_consulta) = $2 AND\nId_med = $3 AND\nhora_consulta >= $4 AND hora_consulta <= $5\nAND estado = 1",
          "options": {
            "queryReplacement": "={{ $json.dia }},{{ $json.mes }},{{ $json.code_med }},{{ $json.hora_inf }},{{ $json.hora_sup }}"
          }
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          448,
          0
        ],
        "id": "fa8743ec-8557-4773-8af1-e2d8419800ad",
        "name": "Consultar Agenda Horas",
        "alwaysOutputData": true,
        "credentials": {
          "mySql": {
            "id": "AhIhzsui7WGvqzct",
            "name": "MySQL Hostinger"
          }
        }
      },
      {
        "parameters": {
          "respondWith": "json",
          "responseBody": "{\n  \"agenda_horas\": \"null\"\n}",
          "options": {}
        },
        "type": "n8n-nodes-base.respondToWebhook",
