        ],
        "id": "81b85fa1-30d7-4b89-98d4-218512fd1ad9",
        "name": "Horas Disponibles"
      },
      {
        "parameters": {
          "jsCode": "const agendaHoras = $input.all();\n\nconst horasDisp = agendaHoras.map((agenda, index) => {\n  const defHora = new Date();\n  const [h, m] = agenda.json.agenda_hora.split(\":\");\n  defHora.setHours(parseInt(h), parseInt(m));\n\n  const formatoHora = defHora.toLocaleTimeString(\"es-CO\", {\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    hour12: true,\n  });\n\n  return {\n    id: index + 1,\n    agenda_code: agenda.json.id,\n    hora: formatoHora,\n  };\n});\n\nconst text = horasDisp.map(({ id, hora }) => `${id}. ${hora}`).join(\"\\n\");\n\nreturn {\n  agenda_horas: horasDisp,\n  text,\n};\n"
        },
