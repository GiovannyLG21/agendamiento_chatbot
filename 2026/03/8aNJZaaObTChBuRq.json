          "responseBody": "={\n  \"paciente\": \"{{ $('Formato Datos').item.json.paciente }}\",\n\"edad\": {{ $('Formato Datos').item.json.edad }},\n\"doc\": \"{{ $('Formato Datos').item.json.num_documento }}\",\n\"telefono\": \"{{ $('Formato Datos').item.json.telefono }}\",\n\"correo\": \"{{ $('Formato Datos').item.json.correo }}\",\n\"eps\": \"{{ $('Formato Datos').item.json.eps }}\",\n\"datos_requeridos\": true\n} ",
