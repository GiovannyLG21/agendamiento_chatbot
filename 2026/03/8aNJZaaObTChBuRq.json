      },
      {
        "parameters": {
          "jsCode": "const data = $input.first().json.body;\nconst {\n  nombre_1,\n  nombre_2,\n  apellido_1,\n  apellido_2,\n  sexo,\n  fecha_nacimiento,\n  tipo_doc,\n  doc,\n  telefono,\n  correo,\n  eps\n} = data;\n\nfunction calcularEdad(fecha) {\n  const fechaActual = new Date();\n  const fechaNacimiento = new Date(fecha);\n\n  let años = fechaActual.getFullYear() - fechaNacimiento.getFullYear();\n  const mes = fechaActual.getMonth() - fechaNacimiento.getMonth();\n  if (\n    mes < 0 ||\n    (mes === 0 && fechaActual.getDate() < fechaNacimiento.getDate())\n  )\n    años--;\n\n  return años;\n}\n\nconst tiposDoc = {\n  \"Tarjeta de identidad\": \"TI\",\n  \"Cedula de ciudadanía\": \"CC\",\n};\n\nconst paciente =\n  nombre_2 == \"Sin segundo nombre\"\n    ? [nombre_1, apellido_1, apellido_2]\n    : [nombre_1, nombre_2, apellido_1, apellido_2];\nconst primerNombre = String(nombre_1).toUpperCase();\nconst segundoNombre =\n  nombre_2 == \"Sin segundo nombre\" ? null : String(nombre_2).toUpperCase();\nconst primerApellido = String(apellido_1).toUpperCase();\nconst segundoApellido = String(apellido_2).toUpperCase();\nconst tipoDocSel = tiposDoc[tipo_doc];\n\nconst [fechaNacDia, fechaNacMes, fechaNacAño] = String(fecha_nacimiento).split(\"/\");\nconst fechaNacFormat = `${fechaNacAño}-${fechaNacMes}-${fechaNacDia}`\nconst edad = calcularEdad(fechaNacFormat);\n\nreturn {\n  paciente: paciente.join(\" \").toLocaleUpperCase(),\n  edad,\n  tipo_doc: tipoDocSel,\n  num_documento: doc,\n  nombre1: primerNombre,\n  nombre2: segundoNombre,\n  apellido1: primerApellido,\n  apellido2: segundoApellido,\n  telefono,\n  correo: String(correo).toLowerCase(),\n  sexo,\n  fecha_nacimiento: fechaNacFormat,\n  eps,\n  origen_chatbot: true\n};\n"
        },
