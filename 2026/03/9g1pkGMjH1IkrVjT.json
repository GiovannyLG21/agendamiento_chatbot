      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT ROW_NUMBER() OVER (ORDER BY fecha_consulta) AS id,\nDAY(`fecha_consulta`) as 'dia', \nMONTH(`fecha_consulta`) as 'mes',\nYEAR(`fecha_consulta`) as 'año'\nFROM u125634063_ins_andes.Agenda\nWHERE Id_med = $1\nAND fecha_consulta >= (CURDATE() + INTERVAL 1 DAY)\nAND estado = 1\nGROUP BY fecha_consulta\nLIMIT 7",
          "options": {
            "queryReplacement": "={{ String($json.code_med) }}"
          }
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          896,
          -96
        ],
        "id": "f615e75c-a0bf-42b0-aa16-04cb50888a1a",
        "name": "Consultar Agenda",
        "alwaysOutputData": true,
        "credentials": {
          "mySql": {
            "id": "AhIhzsui7WGvqzct",
            "name": "MySQL Hostinger"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const agendaDatos = $input.all()\nconst code_med = $('Medico Encontrado').first().json.code_med\n\nfunction obtenerNombreMes(numMes){\n    const fecha = new Date()\n    fecha.setMonth(numMes - 1)\n    return fecha.toLocaleDateString('es-CO', { month: 'long'})\n}\n\nconst agenda = agendaDatos.map(agenda => ({ ...agenda.json, mes_nombre: obtenerNombreMes(agenda.json.mes)}))\n\nconst text = agenda.map(({id, dia, mes_nombre}) => `${id}. ${dia} de ${mes_nombre}`).join('\\n')\n\nreturn {\n  agenda,\n  text,\n  code_med\n}\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1344,
          -192
        ],
        "id": "d6d3581c-bba9-4d46-890d-20057eb6d678",
        "name": "Formato Datos"
      }
