      {
        "parameters": {
          "jsCode": "const medicos = $input.all()\nconst medico_sel = $('Webhook').first().json.body.medico\n\nlet medicoSel = medico_sel.replace(medico_sel.includes('Dr. ') ? 'Dr. ' : 'Dra. ', '')\nif (medicoSel == \"JUAN P. VALENCIA\") medicoSel = \"JUAN PABLO VALENCIA\"\nconst medicoValido = medicos.find(medico => medico.json.nombre == medicoSel)\n\nreturn {\n    code_med: medicoValido ? medicoValido.json.id : \"null\"\n}"
        },
