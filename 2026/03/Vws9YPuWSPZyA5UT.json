      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SET @NOW = '{{ $now.format('yyyy-MM-dd HH:mm:ss') }}';\nSELECT Ag.id, Ag.paciente, Ag.doc_paciente, Pa.correo, Ag.medico, Con.consulta, Ag.fecha_consulta, Ag.hora_consulta, Ag.fecha_agendada, GROUP_CONCAT(Rec.tipo) AS 'recordatorios' FROM Agenda Ag\nJOIN Medicos Med ON Ag.medico = Med.medico\nJOIN Consultas Con ON Med.especialidad = Con.id\nJOIN Pacientes Pa ON Ag.doc_paciente = Pa.num_documento\nLEFT JOIN Recordatorios Rec ON Rec.agenda_id = Ag.id\n  \nWHERE (TIMESTAMP(Ag.fecha_consulta, Ag.hora_consulta) BETWEEN @NOW + INTERVAL 18 HOUR AND @NOW + INTERVAL 30 HOUR\nAND fecha_agendada <= TIMESTAMP(Ag.fecha_consulta, Ag.hora_consulta) - INTERVAL 26 HOUR) \nAND Ag.estado = 2\n\nOR (TIMESTAMP(Ag.fecha_consulta, Ag.hora_consulta) BETWEEN @NOW + INTERVAL 42 HOUR AND @NOW + INTERVAL 54 HOUR\nAND fecha_agendada <= TIMESTAMP(Ag.fecha_consulta, Ag.hora_consulta) - INTERVAL 50 HOUR)\nAND Ag.estado = 2\n\nGROUP BY Ag.id",
          "options": {}
        },
