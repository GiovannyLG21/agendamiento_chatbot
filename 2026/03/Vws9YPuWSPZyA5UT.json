      {
        "parameters": {
          "jsCode": "const citas = $input.all();\n\nconst fechaString = (fecha) =>\n  DateTime.fromFormat(fecha, \"yyyy-MM-dd HH:mm:ss\");\nconst fechaDiff = (fechaSup, fechaInf) =>\n  parseInt(fechaSup.diff(fechaInf, \"hours\").hours.toFixed(2));\n\nconst recordPendientes = citas.reduce((acc, cita) => {\n  const fecha_consulta = cita.json.fecha_consulta;\n  const hora_consulta = cita.json.hora_consulta;\n  const fecha_agendada = cita.json.fecha_agendada;\n  const recordatorios = cita.json.recordatorios;\n\n  const fechaActual = DateTime.now();\n  const fechaCita = fechaString(`${fecha_consulta} ${hora_consulta}`);\n  const fechaAgendada = fechaString(fecha_agendada);\n  const horasRestantes = fechaDiff(fechaCita, fechaActual);\n  const diffFechaAgendada = fechaDiff(fechaCita, fechaAgendada);\n  const tipoRecordatorio =\n    horasRestantes >= 18 && horasRestantes <= 30 ? \"24h\" : \"48h\";\n\n  cita.json.consulta = cita.json.consulta\n    .toLowerCase()\n    .split(\" \")\n    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))\n    .join(\" \");\n  cita.json.tipo_recordatorio = tipoRecordatorio;\n  cita.json.horas_restantes = horasRestantes;\n  cita.json.diffFechaAgendada = diffFechaAgendada;\n  cita.json.fecha_consulta = DateTime.fromFormat(fecha_consulta, \"yyyy-MM-dd\")\n    .setLocale(\"es-CO\")\n    .toLocaleString({\n      day: \"numeric\",\n      month: \"long\",\n      year: \"numeric\",\n    });\n  cita.json.hora_consulta = DateTime.fromFormat(hora_consulta, \"HH:mm:ss\")\n    .setLocale(\"es-CO\")\n    .toLocaleString({\n      hour: \"numeric\",\n      minute: \"numeric\",\n      hour12: true,\n    });\n\n  if (!recordatorios || !recordatorios.includes(tipoRecordatorio))\n    acc.push(cita.json);\n  return acc;\n}, []);\n\nreturn {\n  recordPendientes,\n};\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          352,
          -96
        ],
        "id": "f6d6c95b-5a34-4470-ad77-c729a824e8e5",
        "name": "Definir Recordatorios"
      },
      {
        "parameters": {
          "fromEmail": "=Innovasoft SAS<noreply@innovasoftsas.com>",
          "toEmail": "={{ $json.correo }}",
          "subject": "=[RECORDATORIO] Su cita para {{ $json.consulta }} en Horisoes IPS se encuentra confirmada!",
          "html": "=<article\n        style=\"font-family: 'Roboto', Arial, sans-serif; color: #707070; border: 1px solid lightgray; border-radius: 20px; width: 650px; margin: 0 auto;\">\n        <header\n            style=\"background-color: rgba(30, 144, 255, 0.10); padding: 20px 10px; border-top-left-radius: 20px; border-top-right-radius: 20px;\">\n<div style=\"width: fit-content; margin: 0px auto;\">\n\n<h1 style=\"font-size: 18px; text-align: center\">Recordatorio de Cita</h1>\n</div>\n        </header>\n        <section style=\"background-color: white; padding: 15px 45px 25px\">\n            <p style=\"font-size: 15px;\">\n                Estimad@ <strong style=\"color: dodgerblue\">{{ $json.paciente }}</strong>, te recordamos que tienes una nueva cita.\n            </p>\n            <br />\n            <h2 style=\"font-size: 16px; margin-bottom: 25px; color: dodgerblue; font-weight: bolder;\">\n                Datos de la cita\n            </h2>\n            <div style=\"font-size: 14px;\">\n                <p>\n                    <strong style=\"color: dodgerblue\">Médico:</strong> {{ $json.medico }}\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Especialidad:</strong> {{ $json.consulta.toUpperCase() }}\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Sede:</strong> Horisoes IPS\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Dirección:</strong> Cl. 15 Nte. #7n 67\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Fecha:</strong> {{ $json.fecha_consulta }}\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Hora:</strong> {{ $json.hora_consulta }}\n                </p>\n                <p>\n                    <strong style=\"color: dodgerblue\">Código de cita:</strong> {{ $json.id }}\n                </p>\n            </div>\n            <div style=\"margin-top: 40px\">\n                <a href=\"https://wa.link/f7f2nk\" target=\"_blank\"\n                    style=\"background-color: dodgerblue; color: white; padding: 10px 15px; border-radius: 5px; text-decoration: none; \">\n                    Cancelar Cita\n                </a>\n            </div>\n            <div style=\"background-color:lightgray; width: 80%; height: 1px; margin-top: 50px;\"></div>\n            <h4 style=\"font-weight: bolder; color: dodgerblue;\">¡IMPORTANTE!</h4>\n            <p style=\"line-height: 2;\">Asistir con su documento de identidad y/o carné. Preséntese con 20 minutos de\n                anticipación. En caso que\n                no pueda asistir a la cita, por favor cancelarla en nuestros canales virtuales, como respuesta a la\n                notificación que llegará a su correo o en nuestra\n                línea de citas. Llevar su cuota moderadora. A la cita debe asistir el paciente. Si la cita es para un\n                menor de edad, el mismo debe asistir acompañado de un adulto. Si su cita requiere orden medica, tenga en\n                cuenta su vigencia y presentarla al momento del anuncio de su cita. Recuerde presentar en físico los\n                resultados de laboratorios, radiología, ecografía u otros.</p>\n        </section>\n    </article>",
          "options": {
            "appendAttribution": false
          }
        },
