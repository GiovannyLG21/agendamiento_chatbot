      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT Agenda.id as 'code', Agenda.id_med, Agenda.medico, Consultas.consulta AS 'especialidad', Agenda.paciente, Agenda.fecha_consulta as 'fecha', Agenda.hora_consulta AS 'hora'\nFROM  u125634063_ins_andes.Agenda\nJOIN Medicos ON Agenda.id_med = Medicos.id\nJOIN Consultas ON Medicos.especialidad = Consultas.id\nWHERE doc_paciente = $1 \nAND estado = 2\nAND (\n      fecha_consulta > CURDATE()\n      OR (\n          fecha_consulta = CURDATE()\n          AND Hora_consulta > CURTIME()\n      )\n)\nORDER BY fecha_consulta DESC\nLIMIT 1;",
          "options": {
            "queryReplacement": "={{ $json.body.doc }}"
          }
        },
