        "id": "29ac90b2-84e3-4be7-8969-b460c8c6fe1d",
        "name": "Cita Activa"
      },
      {
        "parameters": {
          "jsCode": "const citaData = $input.first().json\n\nconst fechaCita = new Date(citaData.fecha)\nconst [h, m] = citaData.hora.split(':')\nfechaCita.setHours(parseInt(h), parseInt(m))\n\nconst formatoFecha = fechaCita.toLocaleDateString('es-CO', {\n  year: 'numeric',\n  month: 'long',\n  day: '2-digit'\n})\n\nconst formatoHora = fechaCita.toLocaleTimeString('es-CO', {\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: true\n})\n\nreturn { \n  ...citaData, \n  fecha: formatoFecha, \n  hora: formatoHora\n}\n"
        },
